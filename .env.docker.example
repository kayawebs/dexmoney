# Copy to .env.docker on the server and edit only when container/network names differ.
#
# The app containers read normal strategy/secrets settings from .env, then these
# Docker-specific values override localhost URLs for container networking.

DEXMONEY_DOCKER_NETWORK=dexmoney_default
BASE_NODE_DOCKER_NETWORK=node_default
DEXMONEY_IMAGE_TAG=latest

POSTGRES_URL_DOCKER=postgres://user:password@base-arb-postgres:5432/base_arb
REDIS_URL_DOCKER=redis://base-arb-redis:6379
BASE_RPC_HTTP_DOCKER=http://node-execution-1:8545
BASE_RPC_WS_DOCKER=ws://node-execution-1:8546

# Bind monitor-web to localhost by default. Put it behind SSH tunnel or reverse
# proxy instead of exposing it directly.
MONITOR_WEB_BIND=127.0.0.1
MONITOR_WEB_PORT=8085
